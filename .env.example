# LEC US Entry Radar — Environment Variables
# Copy this file to .env and fill in your API keys
# All keys are free tier — see README.md for step-by-step instructions

# Nutritionix API (nutritionix.com/business/api)
VITE_NUTRITIONIX_APP_ID=your_nutritionix_app_id
VITE_NUTRITIONIX_APP_KEY=your_nutritionix_app_key

# Kroger API (developer.kroger.com)
VITE_KROGER_CLIENT_ID=your_kroger_client_id
VITE_KROGER_CLIENT_SECRET=your_kroger_client_secret

# Yelp Fusion API (yelp.com/developers)
VITE_YELP_API_KEY=your_yelp_api_key

# YouTube Data API v3 (console.cloud.google.com)
VITE_YOUTUBE_API_KEY=your_youtube_api_key

# NewsAPI (newsapi.org)
VITE_NEWS_API_KEY=your_newsapi_key

# SerpAPI (serpapi.com)
VITE_SERPAPI_KEY=your_serpapi_key

# Anthropic Claude API (console.anthropic.com)
VITE_ANTHROPIC_KEY=your_anthropic_api_key
